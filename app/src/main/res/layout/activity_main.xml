<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"
            android:text="Status: starting…" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDiscoverable"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Make discoverable" />

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Connect paired" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modifiers (hold = toggle on, then tap a key)" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <ToggleButton
                android:id="@+id/tglCtrl"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textOff="Ctrl"
                android:textOn="Ctrl ✓" />

            <ToggleButton
                android:id="@+id/tglAlt"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textOff="Opt"
                android:textOn="Opt ✓" />

            <ToggleButton
                android:id="@+id/tglShift"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textOff="Shift"
                android:textOn="Shift ✓" />

            <ToggleButton
                android:id="@+id/tglGui"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textOff="Cmd"
                android:textOn="Cmd ✓" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="Special keys" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnEsc" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Esc" />
            <Button android:id="@+id/btnTab" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Tab" />
            <Button android:id="@+id/btnEnter" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Enter" />
            <Button android:id="@+id/btnBksp" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Bksp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="Arrows" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button android:id="@+id/btnUp" android:layout_width="64dp" android:layout_height="wrap_content" android:text="↑" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button android:id="@+id/btnLeft" android:layout_width="64dp" android:layout_height="wrap_content" android:text="←" />
            <Button android:id="@+id/btnDown" android:layout_width="64dp" android:layout_height="wrap_content" android:text="↓" />
            <Button android:id="@+id/btnRight" android:layout_width="64dp" android:layout_height="wrap_content" android:text="→" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live typing — keys are sent as you type (no Send needed)" />

        <EditText
            android:id="@+id/etText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Type here — goes straight to the iPad"
            android:inputType="textMultiLine|textNoSuggestions"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Clear field" />
    </LinearLayout>
</ScrollView>
