# Copy to .env and fill in. Values mirror the relay's control panel.

# --- Relay (the "hands") ---
RELAY_HOST=127.0.0.1
RELAY_PORT=47600
RELAY_PIN=            # the PIN shown in the relay desktop control panel

# Pointer mapping:
#   abs  = use the relay's absolute `moveto` (relay >= 0.8.0) — preferred, deterministic
#   warp = relative-only fallback (Bluetooth-HID path / old relay); keep target mouse accel off
MOUSE_MODE=abs
ACTION_PAUSE=0.4       # seconds between actions (let the target UI settle)

# --- Screen capture (what the model "sees") ---
# local   = grab this machine's display via mss (one-box testing / agent on the Linux target)
# capture = grab an HDMI->USB capture card via ffmpeg (true out-of-band; target unmodified)
SCREEN_SOURCE=local
MONITOR=1
CAPTURE_DEVICE=/dev/video0
CAPTURE_WIDTH=1920
CAPTURE_HEIGHT=1080

# --- Live screen stream to the phone browser (stream.py) ---
# Serves the captured screen as MJPEG so the phone can watch what you are driving.
# Open  http://<this-host-LAN-ip>:STREAM_PORT/?token=<STREAM_PIN>  on the phone.
STREAM_PORT=47700
STREAM_FPS=12          # serve-rate cap (static screens auto-throttle lower)
STREAM_QUALITY=60      # JPEG quality 1..95
STREAM_MAX_EDGE=1280   # downscale so the long edge is at most this many px
STREAM_PIN=            # token to gate the stream (defaults to RELAY_PIN if blank)
# STREAM_SOURCE defaults to SCREEN_SOURCE above (local | capture | test)

# --- Safety / limits ---
MAX_STEPS=40
REQUIRE_CONFIRM=1      # prompt before risky actions (drags, model-flagged ones); 0 to disable

# --- Gemini (priority) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-computer-use-preview-10-2025

# --- Anthropic (alternative) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
